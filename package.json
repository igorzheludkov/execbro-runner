{
    "name": "execbro-runner",
    "version": "0.1.0",
    "description": "Autonomous task runner for ExecBro: enqueue agent tasks, run them in isolated sandboxes, push results to Bitbucket.",
    "type": "module",
    "bin": {
        "execbro-task": "./build/cli/task.js",
        "execbro-worker": "./build/worker/daemon.js"
    },
    "scripts": {
        "build": "tsc && chmod 755 build/cli/task.js build/worker/daemon.js",
        "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
        "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest --testPathPatterns='test/unit'",
        "test:integration": "NODE_OPTIONS='--experimental-vm-modules' jest --testPathPatterns='test/integration'"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "files": [
        "build",
        "templates"
    ],
    "dependencies": {
        "chokidar": "^4.0.1",
        "commander": "^12.1.0",
        "proper-lockfile": "^4.1.2",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/jest": "^29.5.13",
        "@types/node": "^22.7.4",
        "@types/proper-lockfile": "^4.1.4",
        "jest": "^29.7.0",
        "ts-jest": "^29.2.5",
        "typescript": "^5.6.3"
    }
}
